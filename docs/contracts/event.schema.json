{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newslayer.local/schemas/event.schema.json",
  "title": "Newslayer Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "category",
    "status",
    "event_type",
    "title",
    "summary_1l",
    "assets",
    "topics",
    "entities",
    "published_at",
    "updated_at",
    "first_seen_at",
    "last_verified_at",
    "importance_score",
    "confidence_score",
    "source_cluster_size",
    "supporting_articles",
    "rights"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_[a-z0-9_]+$"
    },
    "category": {
      "type": "string",
      "enum": ["crypto"]
    },
    "status": {
      "type": "string",
      "enum": [
        "single_source",
        "multi_source_verified",
        "official_source_confirmed"
      ]
    },
    "event_type": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary_1l": {
      "type": "string",
      "minLength": 1
    },
    "summary_5l": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 5
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "first_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "importance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "market_relevance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_cluster_size": {
      "type": "integer",
      "minimum": 1
    },
    "supporting_articles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/article"
      },
      "minItems": 1
    },
    "rights": {
      "$ref": "#/$defs/rights"
    },
    "markdown_url": {
      "type": "string"
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "name"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "asset",
            "protocol",
            "exchange",
            "regulator",
            "person",
            "company",
            "region"
          ]
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "article": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "article_id",
        "source",
        "url",
        "published_at",
        "editorial_type"
      ],
      "properties": {
        "article_id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "editorial_type": {
          "type": "string",
          "enum": [
            "report",
            "analysis",
            "opinion",
            "press_release",
            "sponsored",
            "rumor",
            "official_announcement"
          ]
        }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_mode",
        "full_text_stored",
        "excerpt_allowed"
      ],
      "properties": {
        "storage_mode": {
          "type": "string",
          "enum": [
            "metadata_only",
            "metadata_plus_excerpt",
            "metadata_plus_summary",
            "full_text_allowed"
          ]
        },
        "full_text_stored": {
          "type": "boolean"
        },
        "excerpt_allowed": {
          "type": "boolean"
        }
      }
    }
  }
}

